# ---- AI Gateway environment template ----
# Copy to .env and fill in secrets:  cp .env.example .env

# Embedding provider (openai | tei) — local TEI is the default
EMBEDDING_PROVIDER=tei
TEI_URL=http://text-embeddings:8080

# OpenAI / Azure OpenAI (only used when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI: set OPENAI_BASE_URL to your Azure resource endpoint and the
# provider auto-switches to the Azure dialect (api-key header, deployment path).
# OPENAI_BASE_URL=https://aiusecases-ins.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=        # deployment name from Azure portal → Deployments (defaults to OPENAI_EMBEDDING_MODEL)
# AZURE_OPENAI_API_VERSION=2024-10-21
# OPENAI_API_TYPE=azure           # optional explicit override; auto-detected from *.azure.com host

# Document text extraction for the /generate path (Apache Tika server)
TIKA_URL=http://tika:9998

# Text generation provider (claude-sdk | anthropic-api)
AI_PROVIDER=claude-sdk
AI_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
